<%= form_with(model: task, class: "space-y-6") do |form| %>
<% if task.errors.any? %>
<div class="rounded-lg bg-rose-50 border border-rose-200/60 px-4 py-3 text-sm text-rose-700">
    <div class="flex items-center gap-2 font-semibold mb-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= t("errors.messages.not_saved", count: task.errors.count, resource: Task.model_name.human) %>
    </div>
    <ul class="list-disc list-inside space-y-0.5 text-rose-600">
        <% task.errors.each do |error| %>
        <li><%= error.full_message %></li>
        <% end %>
    </ul>
</div>
<% end %>

<div>
    <%= form.label :title, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_field :title, class: "w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors", placeholder: t("tasks.form.title_placeholder") %>
</div>

<div>
    <%= form.label :description, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_area :description, rows: 4, class: "w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors", placeholder: t("tasks.form.description_placeholder") %>
</div>

<div>
    <%= form.label :due_on, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.date_field :due_on, class: "rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors" %>
</div>

<div class="grid grid-cols-2 gap-4">
    <div>
        <%= form.label :status, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.select :status,
              Task.statuses.keys.map {|k| [t("activerecord.attributes.task.statuses.#{k}"), k ]},
              {},
              class: "w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors cursor-pointer" %>
    </div>
    <div>
        <%= form.label :priority, class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.select :priority,
              Task.priorities.keys.map {|k| [t("activerecord.attributes.task.priorities.#{k}"), k ]},
              {},
              class: "w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-colors cursor-pointer" %>
    </div>
</div>

<div class="pt-2">
    <%= form.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium py-2.5 px-6 rounded-lg transition-all hover:shadow-md active:scale-[0.98] cursor-pointer" %>
</div>
<% end %>
