<%= form_with(model: task, class: "space-y-5") do |form| %>
<% if task.errors.any? %>
<div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
    <h2 class="font-semibold mb-1"><%= t(
        "errors.messages.not_saved",
        count: task.errors.count,
        resource: Task.model_name.human
    )%></h2>

    <ul class="list-disc list-inside space-y-0.5">
        <% task.errors.each do |error| %>
        <li><%= error.full_message %></li>
        <% end %>
    </ul>
</div>
<% end %>

<div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
</div>

<div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
</div>

<div>
    <%= form.label :due_on, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.date_field :due_on, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
</div>

<div>
    <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.select :status,
          Task.statuses.keys.map {|k| [t("activerecord.attributes.task.statuses.#{k}"), k ]},
          {},
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
</div>

<div>
    <%= form.label :priority, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.select :priority,
          Task.priorities.keys.map {|k| [t("activerecord.attributes.task.priorities.#{k}"), k ]},
          {},
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
</div>

<div>
    <%= form.submit class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-6 rounded-lg transition-colors cursor-pointer" %>
</div>
<% end %>
