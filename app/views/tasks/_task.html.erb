<%= link_to task_path(task), class: "block group", data: { turbo_frame: "_top" } do %>
<div id="<%= dom_id task %>" class="bg-white rounded-xl border border-slate-200/60 shadow-sm hover:shadow-md hover:border-slate-300/60 transition-all duration-200 p-5">
    <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
            <h3 class="text-base font-semibold text-slate-900 truncate group-hover:text-indigo-600 transition-colors">
                <%= task.title %>
            </h3>
            <% if task.description.present? %>
            <p class="mt-1 text-sm text-slate-500 line-clamp-2"><%= task.description %></p>
            <% end %>
        </div>
        <div class="flex items-center gap-2 shrink-0">
            <%= status_badge(task) %>
            <%= priority_badge(task) %>
        </div>
    </div>

    <% if task.due_on.present? %>
    <div class="mt-3 pt-3 border-t border-slate-100">
        <%= due_on_display(task) %>
    </div>
    <% end %>
</div>
<% end %>
