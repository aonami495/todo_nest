<% content_for :title, t("tasks.show.title") %>

<% if notice.present? %>
<div class="mb-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
    <%= notice %>
</div>
<% end %>

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <div class="flex items-start justify-between gap-4 mb-4">
            <h1 class="text-xl font-bold text-gray-900"><%= @task.title %></h1>
            <div class="flex items-center gap-2 shrink-0">
                <%= status_badge(@task) %>
                <%= priority_badge(@task) %>
            </div>
        </div>

        <% if @task.description.present? %>
        <div class="mb-4">
            <h2 class="text-sm font-medium text-gray-700 mb-1"><%= Task.human_attribute_name(:description) %></h2>
            <p class="text-sm text-gray-600"><%= @task.description %></p>
        </div>
        <% end %>

        <div class="mb-4">
            <h2 class="text-sm font-medium text-gray-700 mb-1"><%= Task.human_attribute_name(:due_on) %></h2>
            <p class="text-sm text-gray-600"><%= @task.due_on || "-" %></p>
        </div>

        <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
            <%= link_to t("tasks.show.edit_task"), edit_task_path(@task), class: "inline-flex items-center bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium py-2 px-4 rounded-lg transition-colors" %>
            <%= link_to t("tasks.show.back_to_tasks"), tasks_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
            <%= button_to t("tasks.show.delete_task"), @task, method: :delete, class: "ml-auto inline-flex items-center bg-red-50 hover:bg-red-100 text-red-700 text-sm font-medium py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
        </div>
    </div>
</div>
