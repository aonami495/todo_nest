<% content_for :title, t("tasks.show.title") %>

<div class="max-w-2xl mx-auto">
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <%= link_to t("tasks.index.heading"), tasks_path, class: "hover:text-indigo-600 transition-colors" %>
        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-900 font-medium truncate"><%= @task.title %></span>
    </nav>

    <div class="bg-white rounded-xl border border-slate-200/60 shadow-sm overflow-hidden">
        <div class="p-6">
            <div class="flex items-start justify-between gap-4 mb-6">
                <h1 class="text-xl font-bold text-slate-900"><%= @task.title %></h1>
                <div class="flex items-center gap-2 shrink-0">
                    <%= status_badge(@task) %>
                    <%= priority_badge(@task) %>
                </div>
            </div>

            <% if @task.description.present? %>
            <div class="mb-6">
                <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2"><%= Task.human_attribute_name(:description) %></h2>
                <p class="text-sm text-slate-600 leading-relaxed whitespace-pre-wrap"><%= @task.description %></p>
            </div>
            <% end %>

            <div class="grid grid-cols-2 gap-4">
                <div class="rounded-lg bg-slate-50 p-3">
                    <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1"><%= Task.human_attribute_name(:due_on) %></h2>
                    <% if @task.due_on.present? %>
                    <%= due_on_display(@task) %>
                    <% else %>
                    <p class="text-sm text-slate-400">&mdash;</p>
                    <% end %>
                </div>
                <div class="rounded-lg bg-slate-50 p-3">
                    <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1"><%= Task.human_attribute_name(:created_at) %></h2>
                    <p class="text-xs text-slate-500"><%= l(@task.created_at, format: :short) %></p>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3 px-6 py-4 border-t border-slate-100 bg-slate-50/50">
            <%= link_to edit_task_path(@task), class: "inline-flex items-center gap-1.5 bg-white border border-slate-200 hover:border-slate-300 text-slate-700 text-sm font-medium py-2 px-4 rounded-lg transition-all hover:shadow-sm" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            <%= t("tasks.show.edit_task") %>
            <% end %>

            <%= link_to tasks_path, class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" do %>
            <%= t("tasks.show.back_to_tasks") %>
            <% end %>

            <%= button_to @task, method: :delete, class: "ml-auto inline-flex items-center gap-1.5 text-rose-600 hover:text-rose-700 hover:bg-rose-50 text-sm font-medium py-2 px-3 rounded-lg transition-colors cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            <%= t("tasks.show.delete_task") %>
            <% end %>
        </div>
    </div>
</div>
