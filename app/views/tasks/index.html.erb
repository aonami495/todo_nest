<% content_for :title, t("tasks.index.title") %>

<div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 tracking-tight"><%= t("tasks.index.heading") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("tasks.index.count", count: @tasks.size) %></p>
</div>

<div class="flex flex-wrap items-center gap-3 mb-8">
    <nav class="flex items-center gap-1 bg-white rounded-lg border border-slate-200/60 p-1 shadow-sm">
        <%= link_to t("tasks.filters.all"), tasks_path(sort: params[:sort]),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:status].blank? ? 'bg-indigo-600 text-white shadow-sm' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}" %>
        <% Task.statuses.keys.each do |s| %>
        <%= link_to t("activerecord.attributes.task.statuses.#{s}"), tasks_path(status: s, sort: params[:sort]),
            class: "px-3 py-1.5 text-sm font-medium rounded-md transition-colors #{params[:status] == s ? 'bg-indigo-600 text-white shadow-sm' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}" %>
        <% end %>
    </nav>

    <div class="ml-auto">
        <%= form_with url: tasks_path, method: :get, local: true, class: "flex items-center gap-2" do %>
        <%= hidden_field_tag :status, params[:status] %>
        <%= select_tag :sort,
            options_for_select(
                [
                    [t("tasks.filters.sort_options.due_on_asc"), "due_on_asc"],
                    [t("tasks.filters.sort_options.priority_desc"), "priority_desc"],
                    [t("tasks.filters.sort_options.created_at_desc"), "created_at_desc"]
                ],
                params[:sort]
            ),
            onchange: "this.form.requestSubmit()",
            class: "rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm cursor-pointer" %>
        <% end %>
    </div>
</div>

<% if @tasks.any? %>
<div id="tasks" class="space-y-3">
    <% @tasks.each do |task| %>
    <%= render task %>
    <% end %>
</div>
<% else %>
<div class="text-center py-20">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 mb-4">
        <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
    </div>
    <p class="text-slate-500 text-sm mb-1"><%= t("tasks.index.empty") %></p>
    <p class="text-slate-400 text-xs"><%= t("tasks.index.empty_hint") %></p>
</div>
<% end %>
